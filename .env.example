# Core node settings
NODE_ENV=production
PORT=3000
ORIGIN=http://localhost:3000

# Persistent storage paths (must be backed up together)
DATABASE_PATH=/data/koaladata.db
DATA_DIRECTORY=/data

# Configurable global session options
SESSION_MAX_AGE=2592000

# Initial Admin User seed (Seeded on first startup if no admin exists)
# Required in production; dev server falls back to dev defaults.
KOALADATA_ADMIN_USERNAME=admin
KOALADATA_ADMIN_DISPLAY_NAME="System Admin"
KOALADATA_ADMIN_PASSWORD=change_this_insecure_password_on_first_login
